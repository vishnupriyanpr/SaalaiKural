# ============================================================
#  RoadWatch - IIT-M  |  .gitignore
# ============================================================

# ─── Node.js ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ─── Virtual Environments ───────────────────────────────────
venv/
.venv/

# ─── Environment Variables (keep template, ignore real ones) ─
.env
.env.local
.env.*.local

# ─── Next.js ────────────────────────────────────────────────
.next/
out/

# ─── IDE / OS ───────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
Thumbs.db

# ─── Backend — generated/runtime files ──────────────────────
# Uploaded images (runtime, not source)
backend/uploads/

# YOLO training runs (output artifacts)
backend/runs/

# SQLite databases (auto-created at runtime from db.js schema)
*.db
*.sqlite3

# ─── Keep these important backend files ─────────────────────
# Trained YOLO model weights — include these
!backend/models/best.pt
!backend/yolo26n.pt
!backend/yolov8n.pt

# Dataset — include fully
!backend/dataset/
!backend/dataset/**

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/
